# ═══════════════════════════════════════════════════════════════════
# tredo — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to config/tredo.env and fill in your values.
#   cp config/tredo.env.example config/tredo.env
# Then source it before running:
#   source config/tredo.env
# ═══════════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────
# Options: ollama, openai, claude
LLM_PROVIDER=ollama
LLM_MODEL=nemotron-3-nano:4b
LLM_ENDPOINT=http://localhost:11434

# API keys for cloud LLMs (leave blank if using Ollama)
LLM_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# ── Exchange API Keys (Paper Mode) ────────────────────────────────
# Use dummy values for paper trading. Replace with real keys for live.
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Alpaca Markets US Equities / Crypto Broker API keys
ALPACA_API_KEY_ID=your_alpaca_api_key_id
ALPACA_API_SECRET_KEY=your_alpaca_api_secret_key
ALPACA_PAPER=true

# ── News API (free tiers from research: Finnhub 60/min + sentiment+technicals, Marketaux ~100/day + sentiment, NewsAPI 100/day dev, Alpha Vantage 25/day + 50+ indicators) ─────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key
ALPHA_VANTAGE_KEY=your_free_alpha_vantage_key
FINNHUB_KEY=your_finnhub_free_key
MARKETAUX_KEY=your_marketaux_free_key

# ── More APIs for news analyser + market metrics meter (free/fremium 2026) ─
# Polygon.io: free tier EOD + limited aggs/indicators (US stocks/crypto); POLYGON_API_KEY
POLYGON_API_KEY=
# FRED (St. Louis Fed): free key for macro metrics (rates, CPI, GDP, regime context)
FRED_API_KEY=
# CoinGecko: keyless public (or free demo key) for rich crypto OHLCV/volume/market data - primary supplement for meter on crypto symbols. No key required for basic.

# ── Notifications (Optional) ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WHATSAPP_SID=
WHATSAPP_TOKEN=
WHATSAPP_FROM=

# ── WebSocket & API Server ───────────────────────────────────────
WS_ENABLED=Y
WEB_API_ADDR=0.0.0.0:8082
WS_PORT=8082

# ── Trading Configuration ────────────────────────────────────────
INITIAL_BALANCE=100000
WATCHLIST=BTC,ETH,SOL

# ── Loop Cadences (seconds) ──────────────────────────────────────
# Override the temporal-loop intervals. Defaults match production.
# Lower TREDO_SLOW_LOOP_SECS to OBSERVE the self-evolution / engineering loop
# (reflection → meta-control → rule adapt/revert) during validation runs
# instead of waiting 24h. e.g. TREDO_SLOW_LOOP_SECS=120 for a 2-min cycle.
# TREDO_FAST_LOOP_SECS=5
# TREDO_MEDIUM_LOOP_SECS=30
# TREDO_SLOW_LOOP_SECS=86400

# ── Kronos Forecast Service ──────────────────────────────────────
KRONOS_SERVICE_URL=http://127.0.0.1:8000
# Set to 1 to disable the local `python3 kronos_service/tool.py` subprocess
# fallback when the HTTP service is unreachable. With it disabled, an
# unreachable Kronos service yields no forecast instead of shelling out.
# TREDO_DISABLE_KRONOS_CLI=0

# ── Mode ─────────────────────────────────────────────────────────
# Set to true for paper trading (strongly recommended).
# Set to false only when you have extensively validated the system.
PAPER_MODE=true
