#!/usr/bin/env bash
#
# tredo — Advanced CLI & Production Launcher
# Hermes-style interactive setup wizard + ops.
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"; cd "$ROOT"
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
log() { echo -e "${BLUE}[tredo]${NC} $*"; }
warn() { echo -e "${YELLOW}[tredo WARN]${NC} $*"; }
success() { echo -e "${GREEN}[tredo]${NC} $*"; }
err() { echo -e "${RED}[tredo ERROR]${NC} $*" >&2; }

CONFIG_DIR="${ROOT}/config"; CONFIG_FILE="${CONFIG_DIR}/tredo.env"
GITHUB_RAW_BASE="${GITHUB_RAW_BASE:-https://raw.githubusercontent.com/craaraju-ctrl/Tredo/main}"
mkdir -p "$CONFIG_DIR"

pull_from_github() {
  local path="$1" dest="$2" url="${GITHUB_RAW_BASE}/${path}"
  log "Pulling $path from GitHub..."
  if curl -fsSL "$url" -o "$dest" 2>/dev/null; then success "Pulled $dest"; else
    warn "Could not pull (using local)."; [ -f "$dest" ] || echo "# local default" > "$dest"
  fi
}

run_setup() {
  log "=== tredo Setup Wizard (Hermes-style) ==="
  read -p "Pull latest configs from GitHub? [Y/n] " p; if [[ "${p:-Y}" =~ ^[Yy] ]]; then
    pull_from_github "config/default.yaml" "${CONFIG_DIR}/default.yaml"
    pull_from_github "profiles/watchlist.yaml" "${CONFIG_DIR}/watchlist.yaml" || true
  fi

  echo; log "=== LLM Provider ==="
  echo "1) Ollama (local/remote + model select)  2) OpenAI/GPT  3) Anthropic/Claude  4) Google/Gemini  5) Other"
  read -p "Choice [1]: " c; c=${c:-1}
  case $c in
    1) LLM_PROVIDER=ollama; read -p "Ollama URL [http://localhost:11434]: " e; LLM_ENDPOINT=${e:-http://localhost:11434}
       log "Fetching models..."; curl -s "${LLM_ENDPOINT}/api/tags" | grep -o '"name":"[^"]*"' | cut -d'"' -f4 | nl || true
       read -p "Model [ministral:3b]: " m; LLM_MODEL=${m:-ministral:3b} ;;
    2) LLM_PROVIDER=openai; read -p "OpenAI Key: " -s k; echo; LLM_API_KEY=$k; read -p "Model [gpt-4o]: " m; LLM_MODEL=${m:-gpt-4o}; LLM_ENDPOINT=https://api.openai.com/v1 ;;
    3) LLM_PROVIDER=anthropic; read -p "Claude Key: " -s k; echo; LLM_API_KEY=$k; read -p "Model [claude-3-5-sonnet-20241022]: " m; LLM_MODEL=${m:-claude-3-5-sonnet-20241022}; LLM_ENDPOINT=https://api.anthropic.com ;;
    4) LLM_PROVIDER=gemini; read -p "Gemini Key: " -s k; echo; LLM_API_KEY=$k; read -p "Model [gemini-1.5-flash]: " m; LLM_MODEL=${m:-gemini-1.5-flash}; LLM_ENDPOINT=https://generativelanguage.googleapis.com ;;
    *) LLM_PROVIDER=other; read -p "Provider name: " p; LLM_PROVIDER=$p; read -p "Key: " -s k; echo; LLM_API_KEY=$k; read -p "Endpoint: " e; LLM_ENDPOINT=$e; read -p "Model: " m; LLM_MODEL=$m ;;
  esac

  read -p "OpenAI fallback key? [y/N] " a; [[ $a =~ ^[Yy] ]] && { read -p "Key: " -s k; echo; OPENAI_API_KEY=$k; }
  read -p "Claude fallback key? [y/N] " a; [[ $a =~ ^[Yy] ]] && { read -p "Key: " -s k; echo; CLAUDE_API_KEY=$k; }

  echo; log "=== Broker / News ==="
  read -p "Binance Key (paper OK): " BINANCE_API_KEY; read -p "Binance Secret: " -s BINANCE_API_SECRET; echo
  read -p "NewsAPI key (optional, free dev tier for headlines): " NEWSAPI_KEY
  read -p "Alpha Vantage key (optional, free tier for news + 50+ technical indicators): " ALPHA_VANTAGE_KEY
  read -p "Finnhub key (optional, generous free tier: news, sentiment, precomp technicals, WS): " FINNHUB_KEY
  read -p "Marketaux key (optional, free ~100/day finance news + sentiment scores): " MARKETAUX_KEY
  read -p "Polygon key (optional, free tier aggs + indicators for stocks/crypto meter): " POLYGON_API_KEY
  read -p "FRED key (optional, free St.Louis Fed macro for regime/metrics context): " FRED_API_KEY

  echo; log "=== WhatsApp + Telegram ==="
  read -p "Telegram Bot Token: " TELEGRAM_BOT_TOKEN; read -p "Telegram Chat ID: " TELEGRAM_CHAT_ID
  read -p "WhatsApp SID: " WHATSAPP_SID; read -p "WhatsApp Token: " -s WHATSAPP_TOKEN; echo; read -p "WhatsApp From: " WHATSAPP_FROM

  echo; log "=== WebSocket + Web API ==="
  read -p "Enable WS? [Y/n]: " w; WS_ENABLED=${w:-Y}; read -p "Web API [0.0.0.0:8082]: " a; WEB_API_ADDR=${a:-0.0.0.0:8082}; read -p "WS port [8082]: " p; WS_PORT=${p:-8082}

  read -p "Initial balance [100000]: " b; INITIAL_BALANCE=${b:-100000}
  read -p "Watchlist [NIFTY,RELIANCE,BTC,ETH]: " wl; WATCHLIST=${wl:-NIFTY,RELIANCE,BTC,ETH}

  # Write config with actual values (NOT a quoted heredoc, so vars expand)
  cat > "$CONFIG_FILE" <<EOC
LLM_PROVIDER=$LLM_PROVIDER
LLM_MODEL=$LLM_MODEL
LLM_ENDPOINT=$LLM_ENDPOINT
LLM_API_KEY=${LLM_API_KEY:-}
OPENAI_API_KEY=${OPENAI_API_KEY:-}
CLAUDE_API_KEY=${CLAUDE_API_KEY:-}
BINANCE_API_KEY=${BINANCE_API_KEY:-DUMMY}
BINANCE_API_SECRET=${BINANCE_API_SECRET:-DUMMY}
NEWSAPI_KEY=${NEWSAPI_KEY:-}
ALPHA_VANTAGE_KEY=${ALPHA_VANTAGE_KEY:-}
FINNHUB_KEY=${FINNHUB_KEY:-}
MARKETAUX_KEY=${MARKETAUX_KEY:-}
POLYGON_API_KEY=${POLYGON_API_KEY:-}
FRED_API_KEY=${FRED_API_KEY:-}
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN:-}
TELEGRAM_CHAT_ID=${TELEGRAM_CHAT_ID:-}
WHATSAPP_SID=${WHATSAPP_SID:-}
WHATSAPP_TOKEN=${WHATSAPP_TOKEN:-}
WHATSAPP_FROM=${WHATSAPP_FROM:-}
WS_ENABLED=$WS_ENABLED
WEB_API_ADDR=$WEB_API_ADDR
WS_PORT=$WS_PORT
INITIAL_BALANCE=$INITIAL_BALANCE
WATCHLIST=$WATCHLIST
KRONOS_SERVICE_URL=http://127.0.0.1:8000
PAPER_MODE=true
EOC
  success "Config saved to $CONFIG_FILE"
  read -p "Build project now? [y/N] " ii
  if [[ $ii =~ ^[Yy] ]]; then
    log "Building tredo (this may take several minutes)..."
    if cargo build -p tredo-orchestrator -p tredo-tui; then
      success "Build complete"
    else
      warn "Build had issues — check output above."
    fi
  fi
  read -p "Create symlink in ~/.local/bin? [y/N] " ii
  if [[ $ii =~ ^[Yy] ]]; then mkdir -p ~/.local/bin; ln -sf "$ROOT/tredo" ~/.local/bin/tredo; success "Symlinked to ~/.local/bin/tredo"; fi
  success "Setup done."
  echo "  source $CONFIG_FILE"
  echo "  $ROOT/tredo tui"
  echo
  echo "Or start backend + TUI together:"
  echo "  $ROOT/tredo orchestrator &"
  echo "  $ROOT/tredo tui"
}

print_services() { cat <<'EOP'
Start these first:
1. Ollama: ollama serve & ; ollama pull your-model
2. Kronos: cd kronos_service; pip install -r requirements.txt; uvicorn main:app --port 8000
Then: source config/tredo.env ; ./tredo tui
WS & Web API are inside the orchestrator.
EOP
}

case "${1:-help}" in
  setup|install|wizard) run_setup ;;
  tui) source "$CONFIG_FILE" 2>/dev/null || true; exec cargo run -p tredo-tui ;;
  orchestrator) source "$CONFIG_FILE" 2>/dev/null || true; exec cargo run -p tredo-orchestrator ;;
  build) cargo build --workspace --release ;;
  test) cargo fmt --all -- --check; cargo clippy --workspace --all-targets; cargo test -p tredo-core -p tredo-autonomous ;;
  services) print_services ;;
  meta)
    echo "=== tredo meta (demo self-evolution / adaptation loop) ==="
    echo "The intact system now includes a closed self-evolving loop (Rust core):"
    echo "  Debate (with trained memory recall) -> realistic paper exec (journal/slip) -> auto deep_reflect (trained + regret/lessons) -> MetaControl (applies adaptations like tighter risk on high regret) -> COT visibility + agentmemory persist -> slow loop periodic review."
    echo "Observable in TUI COT: 'debate', 'meta_adapt', 'RULE_ADAPT' events; Rules tab shows updated values."
    echo "To demo: Run paper trades that generate 3+ high-regret (e.g. SL hits); watch auto Meta trigger and rule changes."
    echo "Or force via slow loop / code thresholds. See Build.md 'how to observe'."
    echo "Compounding: Adapted rules (e.g. lower max_risk) affect future validate/risk -> fewer mistakes over cycles."
    ;;
  validate)
    echo "=== tredo validate (REAL-TIME paper crypto validation + self-evolution) ==="
    source "$CONFIG_FILE" 2>/dev/null || true
    # Parse args
    EXTENDED=false
    LONG=false
    CYCLES=10
    DURATION=60
    INDUCE_REGRET=false
    SYMBOLS="${WATCHLIST:-BTC,ETH,SOL}"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --extended) EXTENDED=true; shift ;;
        --long) LONG=true; shift ;;
        --cycles) CYCLES="${2:-50}"; shift 2 ;;
        --duration) DURATION="${2:-300}"; shift 2 ;;
        --induce|--induce-regret) INDUCE_REGRET=true; shift ;;
        --symbols) SYMBOLS="${2:-BTC,ETH}"; shift 2 ;;
        *) shift ;;
      esac
    done

    if [ "$LONG" = true ]; then
      echo "=== tredo LONG-RUN SELF-EVOLUTION VALIDATION ==="
      echo "Symbols: $SYMBOLS"
      echo "Cycles: $CYCLES | Induce regret: $INDUCE_REGRET"
      echo "PAPER_MODE=${PAPER_MODE} (enforced)."
      if [ "$INDUCE_REGRET" = true ]; then
        echo ">>> INDUCING REGRET: Using tight 0.5% SL to force high-regret closes."
        export VALIDATION_INDUCE_REGRET=true
        export VALIDATION_TIGHT_SL_PCT=0.5
      fi
      cargo run -p tredo-orchestrator &
      ORCH_PID=$!
      sleep 8
      echo "Orchestrator started (PID=$ORCH_PID). Running ${CYCLES} pipeline cycles..."
      # Run the SelfEvolutionValidator by triggering cycles via API
      for i in $(seq 1 $CYCLES); do
        for sym in $(echo $SYMBOLS | tr ',' ' '); do
          curl -s --max-time 10 -X POST "http://127.0.0.1:8080/api/trigger_cycle" \
            -H 'content-type: application/json' \
            -d "{\"symbol\":\"$sym\"}" > /dev/null 2>&1 || true
        done
        sleep 3
        if (( i % 10 == 0 )); then
          echo "  ... $i / $CYCLES cycles complete"
        fi
      done
      echo
      echo "=== EVOLUTION ANALYSIS ==="
      DB="tredo_history.db"
      if [ -f "$DB" ]; then
        echo "Per-bucket regret trend (10 episodes per bucket):"
        # Show regret trend across all closed trades ordered by time
        sqlite3 "$DB" "SELECT
          (ROW_NUMBER() OVER (ORDER BY exit_time) - 1) / 10 AS bucket,
          ROUND(AVG(regret_score), 3) AS avg_regret,
          COUNT(*) AS trades,
          SUM(CASE WHEN outcome='WIN' THEN 1 ELSE 0 END) AS wins,
          SUM(CASE WHEN outcome='LOSS' THEN 1 ELSE 0 END) AS losses
        FROM closed_trades
        GROUP BY bucket
        ORDER BY bucket;" 2>/dev/null || echo "(no trades yet)"
        echo
        echo "Rule adaptations applied:"
        sqlite3 "$DB" "SELECT rule_name, old_value, new_value, reason, applied_at FROM rule_changes ORDER BY applied_at;" 2>/dev/null || echo "(none)"
        echo
        echo "High-regret episodes (regret >= 0.65):"
        sqlite3 "$DB" "SELECT symbol, ROUND(regret_score,2), outcome, lesson, exit_time FROM closed_trades WHERE regret_score >= 0.65 ORDER BY exit_time DESC LIMIT 10;" 2>/dev/null || echo "(none)"
      else
        echo "No $DB found."
      fi
      kill $ORCH_PID 2>/dev/null || true
      wait $ORCH_PID 2>/dev/null || true
      echo
      echo "To also compare regret-trend before/after rule adaptation, run:"
      echo "  ./tredo validate --long --cycles 20   # first run (pre-adaptation)"
      echo "  ./tredo validate --long --cycles 20   # second run (post-adaptation)"
      echo "And compare bucket results between the two runs."
      exit 0
    fi

    echo "Live paper crypto on ${SYMBOLS} using real Binance feeds + Ollama debate + autonomous paper exec."
    echo "Mode: ${EXTENDED:+EXTENDED }DURATION=${DURATION}s INDUCE_REGRET=${INDUCE_REGRET}"
    echo "PAPER_MODE=${PAPER_MODE} (enforced)."
    if [ "$INDUCE_REGRET" = true ]; then
      echo ">>> INDUCING REGRET: Using tight risk for validation (expect more SL hits -> meta adaptation)."
      export VALIDATION_INDUCE_REGRET=true
      export VALIDATION_TIGHT_SL_PCT=0.5
    fi
    if [ "$EXTENDED" = true ]; then
      echo ">>> EXTENDED MODE: ${DURATION}s run with periodic pipeline triggers."
    fi
    LOG=/tmp/tredo_validate.log
    > "$LOG"
    ( target/debug/tredo-orchestrator >> "$LOG" 2>&1 & V_PID=$! ; echo "ORCH_PID=$V_PID" >> "$LOG"
      sleep 5
      echo "=== Status ===" >> "$LOG"
      curl -s --max-time 3 "http://127.0.0.1:8080/api/status" | head -c 300 >> "$LOG" || true
      echo >> "$LOG"
      for sym in $(echo $SYMBOLS | tr ',' ' '); do
        echo "Triggering $sym ..." >> "$LOG"
        curl -s --max-time 8 -X POST "http://127.0.0.1:8080/api/trigger_cycle" -H 'content-type: application/json' -d "{\"symbol\":\"$sym\"}" >> "$LOG" || true
        sleep 2
      done
      if [ "$INDUCE_REGRET" = true ]; then
        echo "=== INDUCING REGRET: Forcing a paper trade with tight SL ===" >> "$LOG"
        ENTRY=64500
        TIGHT_SL=64400
        TP=68000
        curl -s --max-time 5 -X POST "http://127.0.0.1:8080/api/trade" -H 'content-type: application/json' -d "{
          \"symbol\": \"BTC\",
          \"direction_str\": \"long\",
          \"entry_price\": $ENTRY,
          \"stop_loss\": $TIGHT_SL,
          \"take_profit\": $TP,
          \"position_size\": 0.001
        }" >> "$LOG" || true
        echo "Forced LONG on BTC with tight SL $TIGHT_SL for regret path" >> "$LOG"
        sleep 8
      fi
      if [ "$EXTENDED" = true ]; then
        echo "=== EXTENDED MODE: running for ${DURATION}s ===" >> "$LOG"
        end=$((SECONDS + DURATION))
        tick=0
        while [ $SECONDS -lt $end ]; do
          tick=$((tick + 1))
          for sym in $(echo $SYMBOLS | tr ',' ' '); do
            curl -s --max-time 5 -X POST "http://127.0.0.1:8080/api/trigger_cycle" -H 'content-type: application/json' -d "{\"symbol\":\"$sym\"}" >> "$LOG" 2>/dev/null || true
          done
          sleep 15
          if (( tick % 4 == 0 )); then
            echo "=== Mid-run status (tick $tick) ===" >> "$LOG"
            curl -s --max-time 3 "http://127.0.0.1:8080/api/status" | head -c 200 >> "$LOG" || true
            echo >> "$LOG"
          fi
        done
      fi
      kill $V_PID 2>/dev/null || true
      wait $V_PID 2>/dev/null || true
    )
    echo "=== VALIDATE SUMMARY ==="
    tail -30 "$LOG" | cat
    echo
    echo "=== EVOLUTION ANALYSIS (regret, meta, compounding from real paper db) ==="
    DB="tredo_history.db"
    if [ -f "$DB" ]; then
      echo "Recent high-regret episodes:"
      sqlite3 "$DB" "SELECT symbol, regret_score, outcome, exit_reason, lesson FROM closed_trades WHERE regret_score > 0.3 ORDER BY exit_time DESC LIMIT 10;" 2>/dev/null || echo "(none)"
      echo
      echo "Regret events for MetaControl:"
      sqlite3 "$DB" "SELECT symbol, regret_score, lesson, rule_violated FROM regret_events ORDER BY recorded_at DESC LIMIT 5;" 2>/dev/null || echo "(none)"
      echo
      echo "Recent rule adaptations:"
      sqlite3 "$DB" "SELECT rule_name, old_value, new_value, reason FROM rule_changes ORDER BY applied_at DESC LIMIT 5;" 2>/dev/null || echo "(none - run with --induce to generate high regret)"
    else
      echo "No $DB found."
    fi
    echo
    echo "For full self-evolution validation with regret trend analysis:"
    echo "  ./tredo validate --long --cycles 50 --induce-regret"
    echo "  ./tredo validate --long --cycles 100 --induce-regret --symbols BTC,ETH"
    echo "See research/remaining-implementation-blueprint-2026.md for details."
    ;;

  *) echo "tredo CLI (setup | tui | orchestrator | build | test | services | meta | validate)"; ./tredo services | head -5 ;;
esac
